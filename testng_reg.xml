<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Regression Suite" parallel="methods" ><!-- thread-count="3"-->
    <listeners>
        <listener class-name="listeners.TestListener"></listener>
        <listener class-name="retry.TestRetryAnalyzerListener"></listener>
        <listener class-name="listeners.SuiteListener"/>
    </listeners>

    <test name="Regression Tests in chrome browser" >

        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>

            <class name="ui_tests.UserLoginLogOutTest"/>
            <class name="ui_tests.InventoryItemsTest"/>
            <class name="ui_tests.CartItemsTest"/>
        </classes>
    </test>
    <!--<test name="Regression Tests in Edge browser" >
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="ui_tests.UserLoginLogOutTest"/>
            <class name="ui_tests.InventoryItemsTest"/>
            <class name="ui_tests.CartItemsTest"/>
        </classes>
    </test> -->
</suite>
